# --- Base de données ---
# Une seule base PostgreSQL est utilisée, aussi bien en local qu'en
# production. Voir le README pour la procédure complète de création sur
# Vercel Postgres (gratuit, aucune ligne de commande requise).
DATABASE_URL="postgresql://user:password@host:5432/database"

# --- Authentification ---
JWT_SECRET="change_this_secret_in_production_please_use_a_long_random_string"

# --- Stockage des fichiers de cours ---
# En local : laissez vide, les fichiers sont stockés sur le disque.
# En production sur Vercel : Vercel injecte automatiquement cette variable
# dès que vous activez "Blob" dans l'onglet Storage de votre projet.
BLOB_READ_WRITE_TOKEN=""

# --- Paiement ---
CINETPAY_API_KEY="your_cinetpay_api_key_here"
CINETPAY_SITE_ID="your_cinetpay_site_id_here"
PAYMENT_MODE="simulation"

# --- Général ---
NEXT_PUBLIC_BASE_URL="http://localhost:3000"
